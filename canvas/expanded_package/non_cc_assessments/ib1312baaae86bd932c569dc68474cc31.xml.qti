ontinue="No"><conditionvar><varequal respident="response1">const_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="iddae200060ecd5489c6d057492b00e3d" title="Equality"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>equality_a1,equality_a2,equality_a3,equality_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which operator checks strict equality in JavaScript?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="equality_a1"><material><mattext texttype="text/html">&lt;p&gt;=&lt;/p&gt;</mattext></material></response_label><response_label ident="equality_a2"><material><mattext texttype="text/html">&lt;p&gt;==&lt;/p&gt;</mattext></material></response_label><response_label ident="equality_a3"><material><mattext texttype="text/html">&lt;p&gt;===&lt;/p&gt;</mattext></material></response_label><response_label ident="equality_a4"><material><mattext texttype="text/html">&lt;p&gt;=&amp;gt;&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">equality_a3</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i21803cf3f6e5aaa38ca32f948928cb1e" title="Template literal"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>template-literal_a1,template-literal_a2,template-literal_a3,template-literal_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which syntax supports embedded expressions in strings?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="template-literal_a1"><material><mattext texttype="text/html">&lt;p&gt;&amp;#x27;single quotes&amp;#x27;&lt;/p&gt;</mattext></material></response_label><response_label ident="template-literal_a2"><material><mattext texttype="text/html">&lt;p&gt;&amp;quot;double quotes&amp;quot;&lt;/p&gt;</mattext></material></response_label><response_label ident="template-literal_a3"><material><mattext texttype="text/html">&lt;p&gt;`backticks`&lt;/p&gt;</mattext></material></response_label><response_label ident="template-literal_a4"><material><mattext texttype="text/html">&lt;p&gt;&amp;lt;tag&amp;gt;&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">template-literal_a3</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i4e0decde102d9230d2bc829a1be19522" title="Array access"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>array-access_a1,array-access_a2,array-access_a3,array-access_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;How do you access the first item in an array named colors?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="array-access_a1"><material><mattext texttype="text/html">&lt;p&gt;colors(0)&lt;/p&gt;</mattext></material></response_label><response_label ident="array-access_a2"><material><mattext texttype="text/html">&lt;p&gt;colors[0]&lt;/p&gt;</mattext></material></response_label><response_label ident="array-access_a3"><material><mattext texttype="text/html">&lt;p&gt;colors.first&lt;/p&gt;</mattext></material></response_label><response_label ident="array-access_a4"><material><mattext texttype="text/html">&lt;p&gt;colors{0}&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">array-access_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i37c95ded4586e13506c2b61bc1c85c95" title="Console"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>true_false_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>console_true,console_false</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;console.log() is useful during debugging because it lets you inspect values while code runs.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="console_true"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="console_false"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">console_true</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="iaa9a9a7d048651cdbf4430de45dbcb9a" title="coercion-output"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>coercion-output_a1,coercion-output_a2,coercion-output_a3,coercion-output_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;What does &lt;code&gt;console.log(1 + '2')&lt;/code&gt; output?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="coercion-output_a1"><material><mattext texttype="text/html">&lt;p&gt;&amp;#x27;12&amp;#x27; (string concatenation because one operand is a string)&lt;/p&gt;</mattext></material></response_label><response_label ident="coercion-output_a2"><material><mattext texttype="text/html">&lt;p&gt;3&lt;/p&gt;</mattext></material></response_label><response_label ident="coercion-output_a3"><material><mattext texttype="text/html">&lt;p&gt;NaN&lt;/p&gt;</mattext></material></response_label><response_label ident="coercion-output_a4"><material><mattext texttype="text/html">&lt;p&gt;A TypeError is thrown&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">coercion-output_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i71af2449ebc7ea2ea18ef8006411d82c" title="loose-equality-risk"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>loose-equality-risk_a1,loose-equality-risk_a2,loose-equality-risk_a3,loose-equality-risk_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A developer writes &lt;code&gt;if (userAge == '28')&lt;/code&gt;. What is the potential problem with this comparison?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="loose-equality-risk_a1"><material><mattext texttype="text/html">&lt;p&gt;It uses type coercion &amp;mdash; == converts types before comparing, which can produce unexpected matches&lt;/p&gt;</mattext></material></response_label><response_label ident="loose-equality-risk_a2"><material><mattext texttype="text/html">&lt;p&gt;It always returns false because the types are different&lt;/p&gt;</mattext></material></response_label><response_label ident="loose-equality-risk_a3"><material><mattext texttype="text/html">&lt;p&gt;The if statement requires braces to work correctly&lt;/p&gt;</mattext></material></response_label><response_label ident="loose-equality-risk_a4"><material><mattext texttype="text/html">&lt;p&gt;This will throw a ReferenceError at runtime&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">loose-equality-risk_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="if171ba608d7865708ffafa45fbb96eec" title="devtools-debugging"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>devtools-debugging_a1,devtools-debugging_a2,devtools-debugging_a3,devtools-debugging_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A function you wrote is returning &lt;code&gt;undefined&lt;/code&gt; instead of the expected value. Which DevTools approach would most directly help you trace the problem?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="devtools-debugging_a1"><material><mattext texttype="text/html">&lt;p&gt;Open the Console tab and add &lt;code&gt;console.log()&lt;/code&gt; calls inside the function to inspect intermediate values and confirm which line produces &lt;code&gt;undefined&lt;/code&gt;&lt;/p&gt;</mattext></material></response_label><response_label ident="devtools-debugging_a2"><material><mattext texttype="text/html">&lt;p&gt;Open the Network tab and check the HTTP status code&lt;/p&gt;</mattext></material></response_label><response_label ident="devtools-debugging_a3"><material><mattext texttype="text/html">&lt;p&gt;Open the Elements tab and inspect the DOM structure&lt;/p&gt;</mattext></material></response_label><response_label ident="devtools-debugging_a4"><material><mattext texttype="text/html">&lt;p&gt;Open the Application tab and clear localStorage&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">devtools-debugging_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item></section></assessment></questestinterop>