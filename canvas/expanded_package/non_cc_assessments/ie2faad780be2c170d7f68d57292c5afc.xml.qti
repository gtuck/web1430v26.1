<?xml version='1.0' encoding='utf-8'?>
<questestinterop xmlns="http://www.imsglobal.org/xsd/ims_qtiasiv1p2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/ims_qtiasiv1p2 http://www.imsglobal.org/xsd/ims_qtiasiv1p2p1.xsd"><assessment ident="ie2faad780be2c170d7f68d57292c5afc" title="Quiz 5 – Fetch and APIs"><qtimetadata><qtimetadatafield><fieldlabel>cc_maxattempts</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield></qtimetadata><section ident="root_section"><item ident="ifd9555da3a1aa4c6942be176a7c67281" title="Fetch result"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>fetch-result_a1,fetch-result_a2,fetch-result_a3,fetch-result_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;fetch() returns:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="fetch-result_a1"><material><mattext texttype="text/html">&lt;p&gt;An HTML element&lt;/p&gt;</mattext></material></response_label><response_label ident="fetch-result_a2"><material><mattext texttype="text/html">&lt;p&gt;A Promise&lt;/p&gt;</mattext></material></response_label><response_label ident="fetch-result_a3"><material><mattext texttype="text/html">&lt;p&gt;A CSS rule&lt;/p&gt;</mattext></material></response_label><response_label ident="fetch-result_a4"><material><mattext texttype="text/html">&lt;p&gt;A local file handle&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">fetch-result_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i9097fba901ff32bf8c6ebe2d3dea78c3" title="JSON response"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>json-response_a1,json-response_a2,json-response_a3,json-response_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which method commonly reads JSON from a response object?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="json-response_a1"><material><mattext texttype="text/html">&lt;p&gt;response.textOnly()&lt;/p&gt;</mattext></material></response_label><response_label ident="json-response_a2"><material><mattext texttype="text/html">&lt;p&gt;response.parse()&lt;/p&gt;</mattext></material></response_label><response_label ident="json-response_a3"><material><mattext texttype="text/html">&lt;p&gt;response.json()&lt;/p&gt;</mattext></material></response_label><response_label ident="json-response_a4"><material><mattext texttype="text/html">&lt;p&gt;response.body()&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">json-response_a3</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i35d9148dba34d486b500b2e593077ab6" title="Async await"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>true_false_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>async-await_true,async-await_false</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;await can make asynchronous code easier to read when used inside an async function.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="async-await_true"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="async-await_false"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">async-await_true</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i3f8efe28eb1657b06ef246a8dea58d39" title="Error handling"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>error-handling_a1,error-handling_a2,error-handling_a3,error-handling_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A good UI response to a failed API request is to:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="error-handling_a1"><material><mattext texttype="text/html">&lt;p&gt;Show nothing and hope it works later&lt;/p&gt;</mattext></material></response_label><response_label ident="error-handling_a2"><material><mattext texttype="text/html">&lt;p&gt;Provide a helpful error state and recovery option&lt;/p&gt;</mattext></material></response_label><response_label ident="error-handling_a3"><material><mattext texttype="text/html">&lt;p&gt;Delete all page content permanently&lt;/p&gt;</mattext></material></response_label><response_label ident="error-handling_a4"><material><mattext texttype="text/html">&lt;p&gt;Reload every 100 milliseconds&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">error-handling_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="ib99090741392863194e19e6bf50d3092" title="Loading state"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>loading-state_a1,loading-state_a2,loading-state_a3,loading-state_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Why use a loading state?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="loading-state_a1"><material><mattext texttype="text/html">&lt;p&gt;To hide all delays from users forever&lt;/p&gt;</mattext></material></response_label><response_label ident="loading-state_a2"><material><mattext texttype="text/html">&lt;p&gt;To communicate that work is in progress and prevent confusion&lt;/p&gt;</mattext></material></response_label><response_label ident="loading-state_a3"><material><mattext texttype="text/html">&lt;p&gt;To disable CSS&lt;/p&gt;</mattext></material></response_label><response_label ident="loading-state_a4"><material><mattext texttype="text/html">&lt;p&gt;To replace validation&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">loading-state_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i7336d1c9686ba13fc4bf952a232df89f" title="missing-ok-check"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>missing-ok-check_a1,missing-ok-check_a2,missing-ok-check_a3,missing-ok-check_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;After &lt;code&gt;const res = await fetch(url)&lt;/code&gt;, a developer immediately calls &lt;code&gt;const data = await res.json()&lt;/code&gt;. What is missing from this code?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="missing-ok-check_a1"><material><mattext texttype="text/html">&lt;p&gt;A check for res.ok — a 404 or 500 response resolves the Promise but res.ok is false, and calling .json() on an error response may throw or return unexpected data&lt;/p&gt;</mattext></material></response_label><response_label ident="missing-ok-check_a2"><material><mattext texttype="text/html">&lt;p&gt;await should not be used with .json()&lt;/p&gt;</mattext></material></response_label><response_label ident="missing-ok-check_a3"><material><mattext texttype="text/html">&lt;p&gt;fetch() already throws an error for 404 responses automatically&lt;/p&gt;</mattext></material></response_label><response_label ident="missing-ok-check_a4"><material><mattext texttype="text/html">&lt;p&gt;The response must be cloned before calling .json()&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">missing-ok-check_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i31114bf978b73128268f06e867b00cb4" title="fetch-resolves-on-404"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>fetch-resolves-on-404_a1,fetch-resolves-on-404_a2,fetch-resolves-on-404_a3,fetch-resolves-on-404_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A developer fetches a URL that returns a 404 status. The &lt;code&gt;await fetch(url)&lt;/code&gt; call does NOT throw an error. Why?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="fetch-resolves-on-404_a1"><material><mattext texttype="text/html">&lt;p&gt;fetch() only rejects on network failures (no connection, DNS failure). HTTP error status codes like 404 resolve successfully — the developer must check res.ok&lt;/p&gt;</mattext></material></response_label><response_label ident="fetch-resolves-on-404_a2"><material><mattext texttype="text/html">&lt;p&gt;404 errors are automatically retried by the browser&lt;/p&gt;</mattext></material></response_label><response_label ident="fetch-resolves-on-404_a3"><material><mattext texttype="text/html">&lt;p&gt;fetch() always throws for any non-200 status&lt;/p&gt;</mattext></material></response_label><response_label ident="fetch-resolves-on-404_a4"><material><mattext texttype="text/html">&lt;p&gt;The try/catch block suppressed the error&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">fetch-resolves-on-404_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item></section></assessment></questestinterop>