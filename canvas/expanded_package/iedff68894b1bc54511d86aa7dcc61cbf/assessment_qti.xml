<questestinterop xmlns="http://www.imsglobal.org/xsd/ims_qtiasiv1p2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/ims_qtiasiv1p2 http://www.imsglobal.org/profile/cc/ccv1p1/ccv1p1_qtiasiv1p2p1_v1p0.xsd"><assessment ident="iedff68894b1bc54511d86aa7dcc61cbf" title="Quiz 8 – Testing, Performance, and Deployment"><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.exam.v0p1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>qmd_assessmenttype</fieldlabel><fieldentry>Examination</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>qmd_scoretype</fieldlabel><fieldentry>Percentage</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>cc_maxattempts</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield></qtimetadata><section ident="root_section"><item ident="i3b3a7ab9c7b28ef009dd41dd30f9f427" title="Lighthouse"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Lighthouse helps evaluate:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="lighthouse_a1"><material><mattext texttype="text/html">&lt;p&gt;Only typography&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse_a2"><material><mattext texttype="text/html">&lt;p&gt;Performance, accessibility, and best practices&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse_a3"><material><mattext texttype="text/html">&lt;p&gt;Only backend queries&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse_a4"><material><mattext texttype="text/html">&lt;p&gt;Only image creation&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">lighthouse_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i5231345cff8f5322e141ecdf6d4096fd" title="Deployment"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.true_false.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Testing a deployed version of a site is important because production behavior can differ from local behavior.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="deployment_true"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="deployment_false"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">deployment_true</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i9a1f20d7cddc00402fb7f2740bd3c83b" title="lighthouse-accessibility-failure"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A Lighthouse audit gives a page an Accessibility score of 62. The most likely cause listed in the report is:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="lighthouse-accessibility-failure_a1"><material><mattext texttype="text/html">&lt;p&gt;Form inputs are missing associated label elements, or images are missing alt attributes — these are the most common Lighthouse accessibility failures&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse-accessibility-failure_a2"><material><mattext texttype="text/html">&lt;p&gt;The page uses too many CSS custom properties&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse-accessibility-failure_a3"><material><mattext texttype="text/html">&lt;p&gt;JavaScript runs before the DOM is ready&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse-accessibility-failure_a4"><material><mattext texttype="text/html">&lt;p&gt;The site is not deployed over HTTPS&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">lighthouse-accessibility-failure_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="icea841aff3cee059a92d77abfdfb072e" title="vite-github-pages-base"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A developer deploys a Vite app to GitHub Pages at &lt;code&gt;https://user.github.io/my-repo/&lt;/code&gt;. Assets load on the homepage but all images and scripts are missing on sub-pages. What is the most likely fix?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="vite-github-pages-base_a1"><material><mattext texttype="text/html">&lt;p&gt;Add base: '/my-repo/' to vite.config.js — without it, Vite generates absolute paths from / which break under a subdirectory&lt;/p&gt;</mattext></material></response_label><response_label ident="vite-github-pages-base_a2"><material><mattext texttype="text/html">&lt;p&gt;Delete the dist/ folder and rebuild&lt;/p&gt;</mattext></material></response_label><response_label ident="vite-github-pages-base_a3"><material><mattext texttype="text/html">&lt;p&gt;Change all import statements to use http:// URLs&lt;/p&gt;</mattext></material></response_label><response_label ident="vite-github-pages-base_a4"><material><mattext texttype="text/html">&lt;p&gt;Enable HTTPS in the GitHub repository settings&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">vite-github-pages-base_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item></section></assessment></questestinterop>