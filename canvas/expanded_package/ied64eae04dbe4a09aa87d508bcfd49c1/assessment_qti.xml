></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">async-model_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i249ce8ba59a1f450f175d0c9d396f67b" title="API design"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;When rendering remote data, a robust interface should handle loading, success, and error states.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="api-design_a1"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="api-design_a2"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">api-design_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i1176466c60cb7603e00df4f568bd385c" title="Storage choice"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A user selects dark mode on your site, closes the browser, and expects that preference to still be there tomorrow. Which storage option is the best fit?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="storage-choice_a1"><material><mattext texttype="text/html">&lt;p&gt;DNS cache&lt;/p&gt;</mattext></material></response_label><response_label ident="storage-choice_a2"><material><mattext texttype="text/html">&lt;p&gt;localStorage&lt;/p&gt;</mattext></material></response_label><response_label ident="storage-choice_a3"><material><mattext texttype="text/html">&lt;p&gt;GPU memory&lt;/p&gt;</mattext></material></response_label><response_label ident="storage-choice_a4"><material><mattext texttype="text/html">&lt;p&gt;HTML comments&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">storage-choice_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i5f136457904bee8c5db42ec9ce2f9408" title="Modules"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Why use modules?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="modules_a1"><material><mattext texttype="text/html">&lt;p&gt;To hide all code from teammates&lt;/p&gt;</mattext></material></response_label><response_label ident="modules_a2"><material><mattext texttype="text/html">&lt;p&gt;To organize and reuse code with clearer boundaries&lt;/p&gt;</mattext></material></response_label><response_label ident="modules_a3"><material><mattext texttype="text/html">&lt;p&gt;To avoid browsers entirely&lt;/p&gt;</mattext></material></response_label><response_label ident="modules_a4"><material><mattext texttype="text/html">&lt;p&gt;To remove testing&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">modules_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i9e03ffda3dff4dd14bd32b01c4269cf9" title="Components"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A component-based framework is most useful when you need to:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="components_a1"><material><mattext texttype="text/html">&lt;p&gt;Repeat structured UI patterns with state and behavior&lt;/p&gt;</mattext></material></response_label><response_label ident="components_a2"><material><mattext texttype="text/html">&lt;p&gt;Write SQL joins&lt;/p&gt;</mattext></material></response_label><response_label ident="components_a3"><material><mattext texttype="text/html">&lt;p&gt;Configure Wi-Fi&lt;/p&gt;</mattext></material></response_label><response_label ident="components_a4"><material><mattext texttype="text/html">&lt;p&gt;Generate PDFs&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">components_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i16ddcba8ff30d4d6f0f885aff7fbc5e5" title="Accessibility"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A user can open a dialog with the keyboard, but after it opens the Tab key skips behind the dialog and lands on the page underneath. What is the biggest accessibility problem?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="accessibility_a1"><material><mattext texttype="text/html">&lt;p&gt;Keyboard users do not have a usable focus path within the active interface&lt;/p&gt;</mattext></material></response_label><response_label ident="accessibility_a2"><material><mattext texttype="text/html">&lt;p&gt;Browsers require a mouse for dialogs&lt;/p&gt;</mattext></material></response_label><response_label ident="accessibility_a3"><material><mattext texttype="text/html">&lt;p&gt;GitHub Pages does not support keyboard events&lt;/p&gt;</mattext></material></response_label><response_label ident="accessibility_a4"><material><mattext texttype="text/html">&lt;p&gt;Screen readers turn off when a dialog opens&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">accessibility_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i2d2a4941d49ccb9059f3b0cf8d78f053" title="Performance habit"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which is a healthy performance habit?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="performance-habit_a1"><material><mattext texttype="text/html">&lt;p&gt;Measure before and after changes&lt;/p&gt;</mattext></material></response_label><response_label ident="performance-habit_a2"><material><mattext texttype="text/html">&lt;p&gt;Guess and assume improvements&lt;/p&gt;</mattext></material></response_label><response_label ident="performance-habit_a3"><material><mattext texttype="text/html">&lt;p&gt;Add every library by default&lt;/p&gt;</mattext></material></response_label><response_label ident="performance-habit_a4"><material><mattext texttype="text/html">&lt;p&gt;Ignore image dimensions&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">performance-habit_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i532be5abeb22acb8a45b0440b5f8fd84" title="Deployment review"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;After deployment, which task is still necessary?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="deployment-review_a1"><material><mattext texttype="text/html">&lt;p&gt;No further work is needed&lt;/p&gt;</mattext></material></response_label><response_label ident="deployment-review_a2"><material><mattext texttype="text/html">&lt;p&gt;Verify links, layout, and interactions in the live environment&lt;/p&gt;</mattext></material></response_label><response_label ident="deployment-review_a3"><material><mattext texttype="text/html">&lt;p&gt;Delete the repo&lt;/p&gt;</mattext></material></response_label><response_label ident="deployment-review_a4"><material><mattext texttype="text/html">&lt;p&gt;Turn off version control&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">deployment-review_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="ibb5da612fb22cbfd040090534dca3eec" title="Portfolio readiness"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A strong final presentation should explain audience, problem, decisions, and evidence of quality.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="portfolio-readiness_a1"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="portfolio-readiness_a2"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">portfolio-readiness_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i66977a4904adb066f8103a1b9b68f01b" title="async-state-machine"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A fetch function renders new content but the loading indicator never disappears after the request completes, even when it succeeds. Where should the code that hides the loading indicator be placed?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="async-state-machine_a1"><material><mattext texttype="text/html">&lt;p&gt;In a finally block — finally runs whether the request succeeds or fails, ensuring the loading state is always cleared&lt;/p&gt;</mattext></material></response_label><response_label ident="async-state-machine_a2"><material><mattext texttype="text/html">&lt;p&gt;In the catch block only&lt;/p&gt;</mattext></material></response_label><response_label ident="async-state-machine_a3"><material><mattext texttype="text/html">&lt;p&gt;Before the await fetch() call&lt;/p&gt;</mattext></material></response_label><response_label ident="async-state-machine_a4"><material><mattext texttype="text/html">&lt;p&gt;In the DOMContentLoaded event listener&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">async-state-machine_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i51c13c93a50c55c34808d87433ad4db9" title="module-dependency-direction"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;In a modular Vite project, &lt;code&gt;api.js&lt;/code&gt; contains a function that calls &lt;code&gt;document.getElementById('results')&lt;/code&gt;. What design rule does this violate?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="module-dependency-direction_a1"><material><mattext texttype="text/html">&lt;p&gt;api.js should have no DOM access — it is responsible for network requests only; DOM manipulation belongs in render.js&lt;/p&gt;</mattext></material></response_label><response_label ident="module-dependency-direction_a2"><material><mattext texttype="text/html">&lt;p&gt;api.js functions must be async, and getElementById is synchronous&lt;/p&gt;</mattext></material></response_label><response_label ident="module-dependency-direction_a3"><material><mattext texttype="text/html">&lt;p&gt;getElementById can only be called from main.js&lt;/p&gt;</mattext></material></response_label><response_label ident="module-dependency-direction_a4"><material><mattext texttype="text/html">&lt;p&gt;This is acceptable as long as api.js does not also use localStorage&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">module-dependency-direction_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="id749c7f6bbb0bd03d46d250d6657fa86" title="vue-props-direction"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A child Vue component needs to tell its parent that a button was clicked. Which pattern should the component use?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="vue-props-direction_a1"><material><mattext texttype="text/html">&lt;p&gt;Emit a custom event with defineEmits and $emit — data flows up via events, not by directly modifying the parent's data&lt;/p&gt;</mattext></material></response_label><response_label ident="vue-props-direction_a2"><material><mattext texttype="text/html">&lt;p&gt;Directly modify the prop passed from the parent&lt;/p&gt;</mattext></material></response_label><response_label ident="vue-props-direction_a3"><material><mattext texttype="text/html">&lt;p&gt;Use localStorage to communicate between components&lt;/p&gt;</mattext></material></response_label><response_label ident="vue-props-direction_a4"><material><mattext texttype="text/html">&lt;p&gt;Call a function on the parent component using document.querySelector&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">vue-props-direction_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="ib8082c79025fb3fbaaec27cb130a94d4" title="gitignore-purpose"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which files should be listed in a &lt;code&gt;.gitignore&lt;/code&gt; for a Vite/Node.js project, and why?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="gitignore-purpose_a1"><material><mattext texttype="text/html">&lt;p&gt;&lt;code&gt;node_modules/&lt;/code&gt; and &lt;code&gt;dist/&lt;/code&gt; — they can be rebuilt from &lt;code&gt;package.json&lt;/code&gt; and source files, so committing them wastes space and creates merge conflicts&lt;/p&gt;</mattext></material></response_label><response_label ident="gitignore-purpose_a2"><material><mattext texttype="text/html">&lt;p&gt;&lt;code&gt;index.html&lt;/code&gt; and &lt;code&gt;style.css&lt;/code&gt; — HTML and CSS should never be committed&lt;/p&gt;</mattext></material></response_label><response_label ident="gitignore-purpose_a3"><material><mattext texttype="text/html">&lt;p&gt;All JavaScript files — only configuration files belong in git&lt;/p&gt;</mattext></material></response_label><response_label ident="gitignore-purpose_a4"><material><mattext texttype="text/html">&lt;p&gt;The &lt;code&gt;.gitignore&lt;/code&gt; file itself — it is generated automatically on push&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">gitignore-purpose_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i1028f71998967edf02ad5cfb0853ce90" title="lighthouse-render-blocking"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A Lighthouse audit flags a page's First Contentful Paint as 'poor.' The page includes &lt;code&gt;&amp;lt;script src="app.js"&amp;gt;&lt;/code&gt; in &lt;code&gt;&amp;lt;head&amp;gt;&lt;/code&gt; without any attributes. Which change would most directly improve this score?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="lighthouse-render-blocking_a1"><material><mattext texttype="text/html">&lt;p&gt;Add &lt;code&gt;defer&lt;/code&gt; — the browser can then parse HTML and download the script in parallel, unblocking the initial render&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse-render-blocking_a2"><material><mattext texttype="text/html">&lt;p&gt;Move the script tag to the bottom of &lt;code&gt;&amp;lt;body&amp;gt;&lt;/code&gt; and remove &lt;code&gt;defer&lt;/code&gt;&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse-render-blocking_a3"><material><mattext texttype="text/html">&lt;p&gt;Add more CSS custom properties to reduce JavaScript size&lt;/p&gt;</mattext></material></response_label><response_label ident="lighthouse-render-blocking_a4"><material><mattext texttype="text/html">&lt;p&gt;Replace all arrow functions with regular function declarations&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">lighthouse-render-blocking_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item></section></assessment></questestinterop>