ue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">es-modules_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i26b74fc7f21805c6f079104eee6b17e8" title="Vite"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Why is Vite helpful for beginners?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="vite_a1"><material><mattext texttype="text/html">&lt;p&gt;It replaces HTML&lt;/p&gt;</mattext></material></response_label><response_label ident="vite_a2"><material><mattext texttype="text/html">&lt;p&gt;It provides a modern development workflow with quick feedback&lt;/p&gt;</mattext></material></response_label><response_label ident="vite_a3"><material><mattext texttype="text/html">&lt;p&gt;It stores passwords&lt;/p&gt;</mattext></material></response_label><response_label ident="vite_a4"><material><mattext texttype="text/html">&lt;p&gt;It removes the need for JavaScript&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">vite_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="ib394c83f4309a8d7f32c4c1c83bb1f28" title="Vue component"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A Vue component is best thought of as:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="vue-component_a1"><material><mattext texttype="text/html">&lt;p&gt;A random folder&lt;/p&gt;</mattext></material></response_label><response_label ident="vue-component_a2"><material><mattext texttype="text/html">&lt;p&gt;A reusable, state-aware interface building block&lt;/p&gt;</mattext></material></response_label><response_label ident="vue-component_a3"><material><mattext texttype="text/html">&lt;p&gt;A database table&lt;/p&gt;</mattext></material></response_label><response_label ident="vue-component_a4"><material><mattext texttype="text/html">&lt;p&gt;A network cable&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">vue-component_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i718a28fdf780eb2b494142c90eda3bcc" title="Reactive state"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.true_false.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;When reactive state changes, Vue can update the view automatically.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="reactive-state_true"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="reactive-state_false"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">reactive-state_true</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="ief2e1c6a7988c104029015f2c91eb6c1" title="Props"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A child Vue component receives &lt;code&gt;count&lt;/code&gt; as a prop and tries to run &lt;code&gt;props.count++&lt;/code&gt; when a button is clicked. What is the better pattern?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="props_a1"><material><mattext texttype="text/html">&lt;p&gt;Emit an event or call a parent-provided handler so the parent updates the prop value&lt;/p&gt;</mattext></material></response_label><response_label ident="props_a2"><material><mattext texttype="text/html">&lt;p&gt;Mutate the prop directly because props are writable local state&lt;/p&gt;</mattext></material></response_label><response_label ident="props_a3"><material><mattext texttype="text/html">&lt;p&gt;Store the new count in &lt;code&gt;localStorage&lt;/code&gt; so the parent sees it&lt;/p&gt;</mattext></material></response_label><response_label ident="props_a4"><material><mattext texttype="text/html">&lt;p&gt;Query the parent DOM and overwrite the rendered text directly&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">props_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="iaa70090492601beafb19beb956f70c84" title="ref-dot-value"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;In a Vue &lt;code&gt;&amp;lt;script setup&amp;gt;&lt;/code&gt; component, a developer declares &lt;code&gt;const count = ref(0)&lt;/code&gt; but writes &lt;code&gt;count = count + 1&lt;/code&gt; in a click handler. What is the problem?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="ref-dot-value_a1"><material><mattext texttype="text/html">&lt;p&gt;ref values must be read and updated through .value — the correct expression is count.value = count.value + 1&lt;/p&gt;</mattext></material></response_label><response_label ident="ref-dot-value_a2"><material><mattext texttype="text/html">&lt;p&gt;ref() is not available inside script setup&lt;/p&gt;</mattext></material></response_label><response_label ident="ref-dot-value_a3"><material><mattext texttype="text/html">&lt;p&gt;count must be declared with let, not const&lt;/p&gt;</mattext></material></response_label><response_label ident="ref-dot-value_a4"><material><mattext texttype="text/html">&lt;p&gt;The click handler must use an arrow function for ref to work&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">ref-dot-value_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i85a26dcecc72d139bcab9423c25aa319" title="named-export-import"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A file exports &lt;code&gt;export function formatPrice(n) { ... }&lt;/code&gt;. Which import statement correctly brings it into another file?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="named-export-import_a1"><material><mattext texttype="text/html">&lt;p&gt;import { formatPrice } from './utils.js'&lt;/p&gt;</mattext></material></response_label><response_label ident="named-export-import_a2"><material><mattext texttype="text/html">&lt;p&gt;import formatPrice from './utils.js'&lt;/p&gt;</mattext></material></response_label><response_label ident="named-export-import_a3"><material><mattext texttype="text/html">&lt;p&gt;import * formatPrice from './utils.js'&lt;/p&gt;</mattext></material></response_label><response_label ident="named-export-import_a4"><material><mattext texttype="text/html">&lt;p&gt;require('./utils.js').formatPrice&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">named-export-import_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item></section></assessment></questestinterop>