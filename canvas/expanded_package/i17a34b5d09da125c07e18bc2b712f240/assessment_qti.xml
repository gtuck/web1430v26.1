tation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">localstorage_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="id4cdfb67f89659f5eddb0b96903826ee" title="Persistence"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.true_false.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Data in localStorage usually remains after the browser tab is closed.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="persistence_true"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="persistence_false"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">persistence_true</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i3a73dab6e60871c4f110b239e84f5fb0" title="sessionStorage"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;sessionStorage differs from localStorage because it is usually scoped to:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="sessionstorage_a1"><material><mattext texttype="text/html">&lt;p&gt;The current browsing session&lt;/p&gt;</mattext></material></response_label><response_label ident="sessionstorage_a2"><material><mattext texttype="text/html">&lt;p&gt;The entire internet&lt;/p&gt;</mattext></material></response_label><response_label ident="sessionstorage_a3"><material><mattext texttype="text/html">&lt;p&gt;The operating system user account&lt;/p&gt;</mattext></material></response_label><response_label ident="sessionstorage_a4"><material><mattext texttype="text/html">&lt;p&gt;The Git branch&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">sessionstorage_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="iaf42453079cbc49bdb218afdf6b3f596" title="State model"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;In UI development, state is best described as:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="state-model_a1"><material><mattext texttype="text/html">&lt;p&gt;The postal location of a user&lt;/p&gt;</mattext></material></response_label><response_label ident="state-model_a2"><material><mattext texttype="text/html">&lt;p&gt;The current data that determines what the interface shows&lt;/p&gt;</mattext></material></response_label><response_label ident="state-model_a3"><material><mattext texttype="text/html">&lt;p&gt;Only CSS colors&lt;/p&gt;</mattext></material></response_label><response_label ident="state-model_a4"><material><mattext texttype="text/html">&lt;p&gt;The browser vendor&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">state-model_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="idb8ae20d11cf7bd0cd4fee2e5a4a403d" title="Serialization"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A developer wants to save the object below in &lt;code&gt;localStorage&lt;/code&gt;:&lt;/p&gt;&lt;pre&gt;&lt;code&gt;const prefs = { theme: 'dark', compact: true }
localStorage.setItem('prefs', ???)&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;What should replace &lt;code&gt;???&lt;/code&gt;?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="serialization_a1"><material><mattext texttype="text/html">&lt;p&gt;JSON.parse(prefs)&lt;/p&gt;</mattext></material></response_label><response_label ident="serialization_a2"><material><mattext texttype="text/html">&lt;p&gt;JSON.stringify(prefs)&lt;/p&gt;</mattext></material></response_label><response_label ident="serialization_a3"><material><mattext texttype="text/html">&lt;p&gt;Object.freeze(prefs)&lt;/p&gt;</mattext></material></response_label><response_label ident="serialization_a4"><material><mattext texttype="text/html">&lt;p&gt;prefs.join(&amp;#x27;,&amp;#x27;)&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">serialization_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i8df09a4ea16d578b02d793ab23ea3944" title="boolean-string-gotcha"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A developer stores &lt;code&gt;localStorage.setItem('active', false)&lt;/code&gt; and later reads &lt;code&gt;if (localStorage.getItem('active'))&lt;/code&gt;. What happens?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="boolean-string-gotcha_a1"><material><mattext texttype="text/html">&lt;p&gt;The condition is true, because localStorage stores the string 'false', and any non-empty string is truthy in JavaScript&lt;/p&gt;</mattext></material></response_label><response_label ident="boolean-string-gotcha_a2"><material><mattext texttype="text/html">&lt;p&gt;The condition is false, as expected, because false was stored&lt;/p&gt;</mattext></material></response_label><response_label ident="boolean-string-gotcha_a3"><material><mattext texttype="text/html">&lt;p&gt;A TypeError is thrown because localStorage cannot store booleans&lt;/p&gt;</mattext></material></response_label><response_label ident="boolean-string-gotcha_a4"><material><mattext texttype="text/html">&lt;p&gt;getItem returns null when the value is false&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">boolean-string-gotcha_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i5a268560ff03c530e09926303544ea9a" title="storage-persistence"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A user closes the browser tab and reopens the same site. Which storage still contains data they saved?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="storage-persistence_a1"><material><mattext texttype="text/html">&lt;p&gt;localStorage — it persists until explicitly cleared, regardless of tab or browser restarts&lt;/p&gt;</mattext></material></response_label><response_label ident="storage-persistence_a2"><material><mattext texttype="text/html">&lt;p&gt;sessionStorage — it persists across all sessions&lt;/p&gt;</mattext></material></response_label><response_label ident="storage-persistence_a3"><material><mattext texttype="text/html">&lt;p&gt;Neither — all Web Storage is cleared when the tab closes&lt;/p&gt;</mattext></material></response_label><response_label ident="storage-persistence_a4"><material><mattext texttype="text/html">&lt;p&gt;Both — they have identical persistence behavior&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">storage-persistence_a1</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item></section></assessment></questestinterop>