<questestinterop xmlns="http://www.imsglobal.org/xsd/ims_qtiasiv1p2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/ims_qtiasiv1p2 http://www.imsglobal.org/profile/cc/ccv1p1/ccv1p1_qtiasiv1p2p1_v1p0.xsd"><assessment ident="i7c38e28c562001e8f7767e66a2ca0437" title="Quiz 4 – DOM, Events, and Forms"><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.exam.v0p1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>qmd_assessmenttype</fieldlabel><fieldentry>Examination</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>qmd_scoretype</fieldlabel><fieldentry>Percentage</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>cc_maxattempts</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield></qtimetadata><section ident="root_section"><item ident="id7ac991aa653aa90489d15ab236692b7" title="Selector"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A developer needs the first required email field on a page. Which method correctly completes the code below?&lt;/p&gt;&lt;pre&gt;&lt;code&gt;const field = document.???('input[type="email"][required]')&lt;/code&gt;&lt;/pre&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="selector_a1"><material><mattext texttype="text/html">&lt;p&gt;getElementByStyle&lt;/p&gt;</mattext></material></response_label><response_label ident="selector_a2"><material><mattext texttype="text/html">&lt;p&gt;querySelector&lt;/p&gt;</mattext></material></response_label><response_label ident="selector_a3"><material><mattext texttype="text/html">&lt;p&gt;firstElement&lt;/p&gt;</mattext></material></response_label><response_label ident="selector_a4"><material><mattext texttype="text/html">&lt;p&gt;matchNode&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">selector_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i1afd983801078eca6332c05496dd9364" title="Event listener"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A button should call &lt;code&gt;saveProfile&lt;/code&gt; only when the user clicks it. The current code runs &lt;code&gt;saveProfile&lt;/code&gt; immediately during page load:&lt;/p&gt;&lt;pre&gt;&lt;code&gt;button.addEventListener('click', saveProfile())&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Which change fixes the problem?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="event-listener_a1"><material><mattext texttype="text/html">&lt;p&gt;button.listen(&amp;#x27;click&amp;#x27;, saveProfile)&lt;/p&gt;</mattext></material></response_label><response_label ident="event-listener_a2"><material><mattext texttype="text/html">&lt;p&gt;button.onClick(saveProfile)&lt;/p&gt;</mattext></material></response_label><response_label ident="event-listener_a3"><material><mattext texttype="text/html">&lt;p&gt;button.addEventListener(&amp;#x27;click&amp;#x27;, saveProfile)&lt;/p&gt;</mattext></material></response_label><response_label ident="event-listener_a4"><material><mattext texttype="text/html">&lt;p&gt;button.bindClick(saveProfile)&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">event-listener_a3</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i8fd59e1b34c65a50d4781e070d419bed" title="Accessible feedback"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which form pattern improves accessibility?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="accessible-feedback_a1"><material><mattext texttype="text/html">&lt;p&gt;Only color-based errors&lt;/p&gt;</mattext></material></response_label><response_label ident="accessible-feedback_a2"><material><mattext texttype="text/html">&lt;p&gt;Clear labels and error text tied to fields&lt;/p&gt;</mattext></material></response_label><response_label ident="accessible-feedback_a3"><material><mattext texttype="text/html">&lt;p&gt;Placeholder text instead of labels&lt;/p&gt;</mattext></material></response_label><response_label ident="accessible-feedback_a4"><material><mattext texttype="text/html">&lt;p&gt;Hidden submit buttons&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">accessible-feedback_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="iccfde4a7233d66bbf1c8939ba96fb5f3" title="Prevent default"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.true_false.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Inside a form submit handler, calling &lt;code&gt;event.preventDefault()&lt;/code&gt; keeps the browser from submitting the form immediately so custom validation can run first.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="prevent-default_true"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="prevent-default_false"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">prevent-default_true</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i63c5d9e273c76991d213cb44f285d1c2" title="State source"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>cc_profile</fieldlabel><fieldentry>cc.multiple_choice.v0p1</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;A validation script needs the text the user has actually typed into an &lt;code&gt;&amp;lt;input&amp;gt;&lt;/code&gt;. Which value should it read?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="state-source_a1"><material><mattext texttype="text/html">&lt;p&gt;The placeholder text shown in the field&lt;/p&gt;</mattext></material></response_label><response_label ident="state-source_a2"><material><mattext texttype="text/html">&lt;p&gt;The control&amp;#x27;s current &lt;code&gt;.value&lt;/code&gt;&lt;/p&gt;</mattext></material></response_label><response_label ident="state-source_a3"><material><mattext texttype="text/html">&lt;p&gt;A hard-coded default&lt;/p&gt;</mattext></material></response_label><response_label ident="state-source_a4"><material><mattext texttype="text/html">&lt;p&gt;The page title&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">state-source_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item></section></assessment></questestinterop>