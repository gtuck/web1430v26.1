          "weight": 100
        },
        {
          "id": "defer-benefit_a2",
          "text": "The script now runs before the DOM is ready, which is faster",
          "html": "<p>The script now runs before the DOM is ready, which is faster</p>",
          "weight": 0
        },
        {
          "id": "defer-benefit_a3",
          "text": "defer causes the script to be cached permanently",
          "html": "<p>defer causes the script to be cached permanently</p>",
          "weight": 0
        },
        {
          "id": "defer-benefit_a4",
          "text": "Moving scripts to head is required for defer to work",
          "html": "<p>Moving scripts to head is required for defer to work</p>",
          "weight": 0
        }
